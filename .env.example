# ─── AURA Marketplace — Environment Variables ───────────────────────────────
# Copy to .env and fill values. Never commit .env to git.

# ── MongoDB (REQUIRED) ──────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/aura_marketplace
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/aura_marketplace
MONGODB_URI=mongodb://localhost:27017/aura_marketplace

# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS — your frontend URL ────────────────────────────────────────────────
# Local dev: leave blank (all localhost origins allowed automatically)
# Production (Vercel): https://aura-marketplace.vercel.app
CLIENT_ORIGIN=

# ── AI Providers — set at least ONE ─────────────────────────────────────────
# Priority: Gemini → Groq → HuggingFace → Krutrim (auto-cascade on failure)
GEMINI_API_KEY=        # aistudio.google.com — free generous quota
GROQ_API_KEY=          # console.groq.com — free
HUGGINGFACE_API_KEY=   # huggingface.co/settings/tokens — free

# ── OSM User-Agent (required by Nominatim ToS) ──────────────────────────────
APP_USER_AGENT=AuraMarketplaceHackathon/1.0 (your@email.com)


# JWT signing secret — REQUIRED for login/signup to work. Generate a long
# random string, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Cloudinary — for profile avatar uploads. Free tier (25GB), no card
# required at signup: https://cloudinary.com/users/register/free
# Without these set, avatar upload returns a clear "not configured" error
# rather than silently failing or storing raw images in MongoDB.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Krutrim Cloud (Ola) — 4th AI fallback provider. Free tier, no card
# required: https://www.olakrutrim.com. Native Hindi/Telugu support is a
# genuine differentiator for this Hyderabad-specific app.
KRUTRIM_API_KEY=

# Ola Maps (Krutrim Cloud) — fallback geocoding if Nominatim fails.
# Free tier, 5 million calls/month, no card required: olakrutrim.com
OLA_MAPS_API_KEY=
