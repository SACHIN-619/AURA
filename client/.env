VITE_MARKETPLACE_DEFAULT_CITY=Hyderabad
VITE_MARKETPLACE_DEFAULT_STATE=Telangana
VITE_MARKETPLACE_COUNTRY_FOCUS=India

# Mirror the backend hubs so frontend can fall back without needing /api/salons/hubs
